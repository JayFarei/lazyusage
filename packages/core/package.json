{
  "name": "lazyusage-core",
  "version": "0.2.2",
  "description": "Core collectors, formatters, and storage for lazyusage CLI monitoring.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "license": "MIT",
  "author": "Jay Farei",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayfarei/lazyusage.git"
  },
  "homepage": "https://github.com/jayfarei/lazyusage#readme",
  "bugs": {
    "url": "https://github.com/jayfarei/lazyusage/issues"
  },
  "keywords": [
    "bun",
    "claude",
    "codex",
    "rate-limit",
    "tui",
    "usage-monitoring"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./parsers/types": {
      "types": "./dist/parsers/types.d.ts",
      "import": "./dist/parsers/types.js"
    },
    "./parsers/claude-parser": {
      "types": "./dist/parsers/claude-parser.d.ts",
      "import": "./dist/parsers/claude-parser.js"
    },
    "./parsers/codex-parser": {
      "types": "./dist/parsers/codex-parser.d.ts",
      "import": "./dist/parsers/codex-parser.js"
    },
    "./parsers/aggregator": {
      "types": "./dist/parsers/aggregator.d.ts",
      "import": "./dist/parsers/aggregator.js"
    },
    "./storage/pace": {
      "types": "./dist/storage/pace.d.ts",
      "import": "./dist/storage/pace.js"
    }
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {}
}
