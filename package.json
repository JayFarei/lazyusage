{
  "name": "lazyusage",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/e2e"
  ],
  "scripts": {
    "build": "bun scripts/build.ts",
    "build:core": "bunx tsc -p packages/core/tsconfig.json",
    "dev": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts packages/cli/src/index.ts",
    "lazyusage": "bun packages/cli/dist/cli.js",
    "lazyusage:dev": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts packages/cli/src/index.ts usage",
    "lazyusage-check": "bun packages/cli/dist/cli.js usage-check",
    "test": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts test",
    "test:core": "bun test tests/core/",
    "test:cli": "bun test tests/cli/",
    "test:tui": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts test tests/tui/",
    "test:e2e": "bun test packages/e2e/src/tests/ --timeout 120000",
    "test:visual": "bun test packages/e2e/src/tests/visual-equivalency.test.ts --timeout 120000",
    "test:soak": "bun test packages/e2e/src/tests/soak.test.ts --timeout 660000",
    "test:soak-chain": "bun scripts/soak-chain.ts",
    "capture-golden": "bun run packages/e2e/scripts/capture-golden.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format . --write",
    "test:dashboard": "bash examples/dashboard/e2e/run-tests.sh",
    "test:smoke": "bun run build && bun packages/cli/dist/cli.js --help >/dev/null && bun packages/cli/dist/cli.js usage-check --help >/dev/null"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@opentui/core": "0.1.77",
    "@opentui/solid": "0.1.77",
    "babel-preset-solid": "^1.9.10",
    "bun-types": "^1.3.9",
    "solid-js": "^1.9.0",
    "typescript": "^5.9.3"
  }
}
