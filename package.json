{
  "name": "usage-tui",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/e2e"
  ],
  "scripts": {
    "dev": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts packages/cli/src/index.ts",
    "usage": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts packages/cli/src/index.ts usage",
    "usage-check": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts packages/cli/src/index.ts usage-check",
    "test": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts test",
    "test:core": "bun test tests/core/",
    "test:cli": "bun test tests/cli/",
    "test:tui": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts test tests/tui/",
    "test:e2e": "bun test packages/e2e/src/tests/ --timeout 120000",
    "test:visual": "bun test packages/e2e/src/tests/visual-equivalency.test.ts --timeout 120000",
    "test:soak": "bun test packages/e2e/src/tests/soak.test.ts --timeout 660000",
    "capture-golden": "bun run packages/e2e/scripts/capture-golden.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@opentui/core": "0.1.77",
    "@opentui/solid": "0.1.77",
    "babel-preset-solid": "^1.9.10",
    "bun-types": "^1.3.9",
    "solid-js": "^1.9.0",
    "typescript": "^5.9.3"
  }
}
