{
  "name": "usage-tui",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/e2e"
  ],
  "scripts": {
    "dev": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts packages/cli/src/index.ts",
    "usage": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts packages/cli/src/index.ts usage",
    "usage-check": "bun --preload=./packages/cli/node_modules/@opentui/solid/scripts/preload.ts packages/cli/src/index.ts usage-check",
    "test": "bun test",
    "test:core": "bun test tests/core/",
    "test:cli": "bun test tests/cli/",
    "test:e2e": "bun test packages/e2e/",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "babel-preset-solid": "^1.9.10",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
